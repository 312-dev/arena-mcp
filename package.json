{
  "name": "arena-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Are.na — create channels, add blocks from any URL, search, and browse your visual boards.",
  "type": "module",
  "bin": {
    "arena-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
